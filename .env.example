# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_NAME="REPAIR MAN"
APP_PORT=8000
API_PREFIX=api

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave unset to allow all (dev only).
ALLOWED_ORIGINS=https://your-admin-domain.com,https://your-app-domain.com

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: connection URL (takes precedence)
# DATABASE_URL=postgresql://user:password@host:5432/repair_man_db

# Option B: individual fields
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=repair_man_db
DATABASE_SYNCHRONIZE=false      # Always false in production — use migrations
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false

# ── JWT ──────────────────────────────────────────────────────────────────────
# Use a long random string: openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret

# ── OTP ──────────────────────────────────────────────────────────────────────
IS_OTP_ENABLED=true             # Set false to use OTP_DEFAULT in dev/staging
OTP_LENGTH=6
OTP_DEFAULT=111111              # Only used when IS_OTP_ENABLED=false
OTP_EXPIRATION_MINUTES=5

# ── Admin seed (run once to create the first admin user) ─────────────────────
